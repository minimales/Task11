# Copy to .env and fill in real values. .env is git-ignored.

# PostgreSQL credentials (used by both the db and app services)
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret for HS256 — MUST be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
